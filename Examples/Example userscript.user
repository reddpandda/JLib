// ==UserScript==
// @name         JLib Example
// @namespace    local.jordan.jlib-example
// @version      1.0.0
// @description  Reference implementation showing how a userscript consumes all five JLib files together.
// @match        *://*/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_registerMenuCommand
// ==/UserScript==
//
// Once the repo is tagged, swap these @require paths for pinned jsDelivr
// URLs (see README.md) instead of local file:// paths:
//   https://cdn.jsdelivr.net/gh/YOUR_USERNAME/YOUR_REPO@1.0.0/src/dom-toolkit.js
// @require      file:///PATH_TO_REPO/src/dom-toolkit.js
// @require      file:///PATH_TO_REPO/src/settings-schema.js
// @require      file:///PATH_TO_REPO/src/utils.js
// @require      file:///PATH_TO_REPO/src/settings-panel.js
// @require      file:///PATH_TO_REPO/src/event-delegation.js

(function () {
  'use strict';

  const log = JLib.utils.makeLogger('JLib Example', '1.0.0');

  // ============ SETTINGS PANEL ============
  // Single implicit scope here (no `scopes` passed) — this is the plain
  // starting template. Pass `scopes`/`getCurrentScope` if your script runs
  // across multiple sites and needs the scope-switcher sidebar, the way
  // the source Streaming Suite script did.
  const panel = JLib.settingsPanel.create({
    namespace: 'jlibExample',
    title: 'JLib Example Settings',
    footerText: '💡 A reference implementation, not a real feature set.',
    categories: [
      { id: 'general', label: 'General', icon: '⚙' },
      { id: 'advanced', label: 'Advanced', icon: '🔧' },
    ],
    features: [
      // --- boolean ---
      {
        id: 'enableFeature',
        type: 'boolean',
        label: 'Enable Feature',
        description: 'Master switch for the stuff below',
        default: true,
        category: 'general',
      },
      // --- boolean, parent-gated (sugar for dependsOn) ---
      {
        id: 'subFeature',
        type: 'boolean',
        label: 'Sub-Feature',
        description: 'Only does anything while Enable Feature is on',
        default: true,
        category: 'general',
        parent: 'enableFeature',
      },
      // --- enum ---
      {
        id: 'mode',
        type: 'enum',
        label: 'Mode',
        description: 'How the feature behaves',
        default: 'balanced',
        category: 'general',
        options: [
          { value: 'fast', label: 'Fast' },
          { value: 'balanced', label: 'Balanced' },
          { value: 'thorough', label: 'Thorough' },
        ],
      },
      // --- boolean gated on a specific enum VALUE, not just "parent is on" ---
      // this is what dependsOn covers that `parent` alone can't.
      {
        id: 'thoroughExtra',
        type: 'boolean',
        label: 'Extra Thorough Pass',
        description: "Only available when Mode is set to 'Thorough'",
        default: false,
        category: 'general',
        dependsOn: (s) => s.mode === 'thorough',
      },
      // --- number ---
      {
        id: 'delayMs',
        type: 'number',
        label: 'Delay (ms)',
        description: 'How long to wait before acting',
        default: 250,
        min: 0,
        max: 5000,
        step: 50,
        category: 'advanced',
      },
      // --- text ---
      {
        id: 'ignoreKeyword',
        type: 'text',
        label: 'Ignore Keyword',
        description: 'Skip anything containing this text',
        default: '',
        maxLength: 40,
        category: 'advanced',
      },
      // --- action: no stored value, just a button ---
      {
        id: 'clearCache',
        type: 'action',
        label: 'Clear Cached Data',
        description: 'Wipes anything this script has cached locally',
        buttonLabel: 'Clear Now',
        category: 'advanced',
        onClick: (ctx) => {
          log.log('cache cleared (example — wire up real cache-clearing here)');
          JLib.dom.toast('Cache cleared', { duration: 2000 });
        },
      },
      // --- custom: escape hatch for anything the other 5 types don't cover ---
      {
        id: 'customExample',
        type: 'custom',
        label: 'Custom Row',
        description: 'Anything you want — this one just shows the current value',
        default: 'example-value',
        category: 'advanced',
        render: (value, onChange) => {
          const wrapper = JLib.dom.el('div', { attrs: { style: 'display:flex;justify-content:space-between;align-items:center;width:100%;' } }, [
            JLib.dom.el('span', {}, ['Custom Row']),
            JLib.dom.el('code', {}, [String(value)]),
          ]);
          return wrapper;
        },
      },
    ],
    // Fires after ANY feature change, live or not — good place for a
    // single global side-effect hook instead of branching per feature id
    // deep inside panel logic.
    onFeatureChange: (id, value, scope, ctx) => {
      log.log(`${id} -> ${JSON.stringify(value)}`);
    },
  });

  GM_registerMenuCommand('⚙ JLib Example Settings', panel.toggle);

  // ============ EVENT DELEGATION ============
  // One real listener on document, matched via closest() against whatever
  // matching elements show up now or later (SPA-safe, no per-tile binding).
  const offClick = JLib.events.on(document, 'click', '[data-jlib-example-target]', (e, matched) => {
    log.log('delegated click on', matched);
    JLib.dom.toast('Clicked: ' + matched.textContent.trim(), { duration: 1500 });
  });

  // ============ DEBOUNCE ============
  // Same shape as the clearTimeout/setTimeout pattern this formalizes —
  // scan() only actually runs once mutations settle, not on every single one.
  const debouncedScan = JLib.utils.debounce(() => {
    const settings = panel.getSettings();
    if (!settings.enableFeature) return;
    log.log('scanning page with settings:', settings);
  }, 150);

  const observer = new MutationObserver(debouncedScan);
  observer.observe(document.body, { childList: true, subtree: true });

  // Cleanup path — every listener/observer this script starts gets a way
  // to stop, per the "every timer/observer has an exit" convention.
  window.addEventListener('beforeunload', () => {
    offClick();
    observer.disconnect();
    panel.destroy();
  });

  log.log('loaded');
})();
